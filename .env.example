# ============================================================
# POD PNG Store — Environment Variables
# Copy file này thành .env.local và điền giá trị thực
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- PayPal ---
# Sandbox (để test): tạo app tại developer.paypal.com
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AXxxxxxx...
PAYPAL_CLIENT_SECRET=EExxxxxx...
PAYPAL_MODE=sandbox                           # Đổi thành "live" khi go-live
PAYPAL_WEBHOOK_ID=WH-xxxx...                  # Lấy từ PayPal Developer Dashboard

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000    # Đổi thành domain thực khi deploy

# --- Optional: Email (dùng Resend để gửi email xác nhận) ---
# RESEND_API_KEY=re_xxxx...
# EMAIL_FROM=noreply@yourdomain.com
