# ============================================================
# POD PNG Store — Environment Variables
# Copy file này thành .env.local và điền giá trị thực
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- PayPal ---
# Sandbox (để test): tạo app tại developer.paypal.com
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AXxxxxxx...
PAYPAL_CLIENT_SECRET=EExxxxxx...
PAYPAL_MODE=sandbox                           # Đổi thành "live" khi go-live
PAYPAL_WEBHOOK_ID=WH-xxxx...                  # Lấy từ PayPal Developer Dashboard

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000    # Đổi thành domain thực khi deploy

# --- Cloudflare R2 (upload design file lớn, bypass Vercel 4.5MB limit) ---
CLOUDFLARE_R2_ACCOUNT_ID=                     # Cloudflare Dashboard → R2 → Account ID
CLOUDFLARE_R2_ACCESS_KEY_ID=                  # R2 → Manage R2 API Tokens → Create API token
CLOUDFLARE_R2_SECRET_ACCESS_KEY=              # Cùng nơi tạo token
CLOUDFLARE_R2_BUCKET_NAME=tiklife-designs     # Tên bucket trong R2

# --- Optional: Email (dùng Resend để gửi email xác nhận) ---
# RESEND_API_KEY=re_xxxx...
# EMAIL_FROM=noreply@yourdomain.com

# --- Pinterest (tự động pin sản phẩm sau khi upload) ---
# Hướng dẫn lấy token: developers.pinterest.com → My Apps → Create App
# → Generate Access Token (chọn scope: pins:write, boards:read)
PINTEREST_ACCESS_TOKEN=                          # Access token từ Pinterest Developer Dashboard
PINTEREST_BOARD_ID=                              # Board ID (lấy từ URL board của bạn)
